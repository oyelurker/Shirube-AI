# Google Cloud / Vertex AI Configuration
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_GENAI_USE_VERTEXAI=False
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_LOCATION=us-central1

# BrightData MCP (Web Scraping)
BRIGHTDATA_API_TOKEN=your_brightdata_api_token
API_TOKEN=your_brightdata_mcp_token
WEB_UNLOCKER_ZONE=your_web_unlocker_zone_id
BROWSER_AUTH=your_browser_auth_string

# BigQuery (Data Warehouse)
BIGQUERY_DATASET=shirube_tourism_data

# Neo4j (GraphRAG Knowledge Graph)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password
